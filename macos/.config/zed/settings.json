{
	"edit_predictions": {
		"provider": "zed",
	},
	"agent": {
		"default_profile": "ask",
		"default_model": {
			"provider": "copilot_chat",
			"model": "gpt-5-mini",
			"enable_thinking": true,
			"effort": "high",
		},
		"tool_permissions": {
			"default": "allow",
		},
	},
	"telemetry": {
		"metrics": false,
		"diagnostics": false,
	},
	"vim_mode": true,
	"relative_line_numbers": "enabled",
	"show_whitespaces": "boundary",
	"ui_font_size": 16,
	"buffer_font_size": 16,
	"theme": {
		"mode": "system",
		"light": "One Light",
		"dark": "Tokyo Night",
	},
	"hard_tabs": true,
	"tab_size": 2,
	"wrap_guides": [80, 100],
	"indent_guides": {
		"coloring": "indent_aware",
	},
	"languages": {
		"Python": {
			"hard_tabs": false,
			"tab_size": 4,
		},
		"YAML": {
			"hard_tabs": false,
		},
	},
	"terminal": {
		"shell": {
			"with_arguments": {
				"program": "fish",
				"args": ["-l"],
			},
		},
		"cursor_shape": "bar",
		"blinking": "on",
	},
}
// vim: ft=jsonc
